generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                   String      @id @default(cuid())
  name                 String?
  email                String      @unique
  emailVerified        DateTime?
  image                String?
  plan                 Plan        @default(FREE)
  aiRequestsUsed       Int         @default(0)
  aiRequestsResetAt    DateTime    @default(now())
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  accounts             Account[]
  components           Component[]
  sessions             Session[]
}

model Component {
  id         String          @id @default(cuid())
  userId     String
  name       String
  liquidCode String
  cssCode    String
  jsCode     String
  schemaJson String          @default("{}")
  method     Method          @default(MANUAL)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  status     ComponentStatus @default(DRAFT)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
}

model Guide {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  category  String
  content   String
  viewCount Int      @default(0)
  tags      String[]
  minPlan   Plan     @default(FREE)
  createdAt DateTime @default(now())
}

enum Plan {
  FREE
  INITIAL
  INTER
  MAX
}

enum Method {
  MANUAL
  AI_GENERATED
}

enum ComponentStatus {
  DRAFT
  SAVED
}
